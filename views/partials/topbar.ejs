<header class="topbar">
    <div class="d-flex align-items-center gap-3">
        <button class="sidebar-toggle" id="sidebarToggle" title="Toggle Sidebar">
            <i class="bi bi-list"></i>
        </button>
        
        <div class="d-none d-md-flex align-items-center gap-2">
            <span class="text-muted" style="font-size: 13px;">System</span>
            <i class="bi bi-chevron-right text-muted" style="font-size: 10px;"></i>
            <% if (typeof breadcrumb !== 'undefined' && breadcrumb.length > 0) { %>
                <% breadcrumb.forEach((item, index) => { %>
                    <% if (index === breadcrumb.length - 1) { %>
                        <span class="fw-semibold" style="font-size: 13px; color: var(--color-text);"><%= item.label %></span>
                    <% } else { %>
                        <a href="<%= item.url %>" class="text-muted text-decoration-none" style="font-size: 13px;"><%= item.label %></a>
                        <i class="bi bi-chevron-right text-muted" style="font-size: 10px;"></i>
                    <% } %>
                <% }); %>
            <% } else { %>
                <span class="fw-semibold" style="font-size: 13px; color: var(--color-text);"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></span>
            <% } %>
        </div>
    </div>
    
    <div class="d-flex align-items-center gap-3">
        <% if (user) { %>
            <div class="dropdown">
                <button class="btn btn-icon position-relative border-0" type="button" id="notifDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-bell"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light notif-badge" id="topbar-notif-count" style="font-size: 9px; padding: 3px 5px; display: none;">
                    </span>
                </button>
                <div class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="notifDropdown" style="width: 300px; border-radius: var(--border-radius-md);">
                    <div class="px-3 py-2 border-bottom">
                        <strong class="mb-0">Notifications</strong>
                    </div>
                    <div id="notifications-list" style="max-height: 300px; overflow-y: auto;">
                        <div class="p-3 text-center text-muted small">Loading...</div>
                    </div>
                    <div class="border-top p-2 text-center bg-light">
                        <a href="/notifications" class="text-decoration-none small fw-bold">View All Notifications</a>
                    </div>
                </div>
            </div>
            
            <div class="dropdown">
                <button class="btn border-0 p-0 d-flex align-items-center gap-2" type="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="d-none d-sm-block text-end" style="line-height: 1.2;">
                        <span class="d-block fw-semibold" style="font-size: 13px; color: var(--color-text);">Hello, <%= user.full_name ? user.full_name.split(' ')[0] : 'User' %></span>
                    </span>
                    <i class="bi bi-chevron-down text-muted" style="font-size: 12px;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userMenuDropdown" style="border-radius: var(--border-radius-md);">
                    <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i> Profile</a></li>
                    <li><a class="dropdown-item" href="/profile/password"><i class="bi bi-key me-2"></i> Change Password</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                </ul>
            </div>
        <% } %>
    </div>
</header>

<% if (user) { %>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Fetch unread count on load
    fetch('/notifications/api/count')
    .then(res => res.json())
    .then(data => {
        const badge = document.getElementById('topbar-notif-count');
        if (data.count > 0) {
            badge.innerText = data.count > 99 ? '99+' : data.count;
            badge.style.display = 'block';
        } else {
            badge.style.display = 'none';
        }
        
        // Populate the dropdown placeholder if no unread
        const list = document.getElementById('notifications-list');
        if (data.count === 0) {
            list.innerHTML = '<div class="p-4 text-center text-muted"><i class="bi bi-check-circle fs-3 text-success d-block mb-2"></i><span class="small">No unread notifications</span></div>';
        } else {
            list.innerHTML = '<div class="p-3 text-center text-muted small">You have ' + data.count + ' unread notification(s).<br><a href="/notifications" class="d-block mt-2">View them here</a></div>';
        }
    })
    .catch(err => {
        const list = document.getElementById('notifications-list');
        list.innerHTML = '<div class="p-3 text-center text-muted small">Error loading notifications.</div>';
    });
});
</script>
<% } %>
