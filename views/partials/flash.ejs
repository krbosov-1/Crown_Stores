<div id="server-flash-messages" class="mb-4">
    <% if (typeof messages !== 'undefined') { %>
        <% if (messages.success && messages.success.length > 0) { %>
            <% messages.success.forEach(function(msg) { %>
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert" style="border-radius: var(--border-radius-md); border-left: 4px solid var(--color-success); background-color: var(--color-success-light); border-color: var(--color-success-light);">
                    <i class="bi bi-check-circle-fill me-3 fs-5" style="color: var(--color-success);"></i>
                    <div style="color: var(--color-text);"><%= msg %></div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% }) %>
        <% } %>
        
        <% if (messages.error && messages.error.length > 0) { %>
            <% messages.error.forEach(function(msg) { %>
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert" style="border-radius: var(--border-radius-md); border-left: 4px solid var(--color-danger); background-color: var(--color-danger-light); border-color: var(--color-danger-light);">
                    <i class="bi bi-exclamation-triangle-fill me-3 fs-5" style="color: var(--color-danger);"></i>
                    <div style="color: var(--color-text);"><%= msg %></div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% }) %>
        <% } %>
        
        <% if (messages.warning && messages.warning.length > 0) { %>
            <% messages.warning.forEach(function(msg) { %>
                <div class="alert alert-warning alert-dismissible fade show d-flex align-items-center" role="alert" style="border-radius: var(--border-radius-md); border-left: 4px solid var(--color-warning); background-color: var(--color-warning-light); border-color: var(--color-warning-light);">
                    <i class="bi bi-exclamation-circle-fill me-3 fs-5" style="color: var(--color-warning);"></i>
                    <div style="color: var(--color-text);"><%= msg %></div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% }) %>
        <% } %>
        
        <% if (messages.info && messages.info.length > 0) { %>
            <% messages.info.forEach(function(msg) { %>
                <div class="alert alert-info alert-dismissible fade show d-flex align-items-center" role="alert" style="border-radius: var(--border-radius-md); border-left: 4px solid var(--color-primary); background-color: var(--color-primary-light); border-color: var(--color-primary-light);">
                    <i class="bi bi-info-circle-fill me-3 fs-5" style="color: var(--color-primary);"></i>
                    <div style="color: var(--color-text);"><%= msg %></div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% }) %>
        <% } %>
    <% } %>
</div>
