<% layout('layouts/main') -%>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Change Password</h4>
</div>

<div class="row">
    <div class="col-12 col-md-6 col-lg-5">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">

                <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger shadow-sm rounded-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
    </div>
<% } %>

<% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success shadow-sm rounded-3">
        <i class="bi bi-check-circle-fill me-2"></i> <%= success %>
    </div>
<% } %>

                
                <form action="/profile/password" method="POST">
                    
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold text-uppercase mb-1">Current Password</label>
                        <input type="password" class="form-control bg-light border-0 p-2" name="currentPassword" placeholder="Enter current password" required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold text-uppercase mb-1">New Password</label>
                        <input type="password" class="form-control bg-light border-0 p-2" name="newPassword" placeholder="Enter new password" required>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase mb-1">Confirm New Password</label>
                        <input type="password" class="form-control bg-light border-0 p-2" name="confirmPassword" placeholder="Confirm new password" required>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100 fw-medium shadow-sm">
                        <i class="bi bi-shield-lock me-2"></i> Update Password
                    </button>
                    
                </form>

            </div>
        </div>
    </div>
</div>
