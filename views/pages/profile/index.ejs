<% layout('layouts/main') -%>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">My Profile</h4>
</div>

<div class="row">
    <div class="col-12 col-md-6 col-lg-5">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 text-center">
                
                <div class="mb-3">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 80px; height: 80px; font-size: 2.5rem;">
                        <i class="bi bi-person"></i>
                    </div>
                </div>
                
                <h5 class="fw-bold mb-1"><%= user.full_name || 'System User' %></h5>
                <p class="text-muted mb-4 badge bg-light text-dark"><%= user.role || 'Admin' %></p>
                
                <ul class="list-group list-group-flush text-start">
                    <li class="list-group-item px-0 pb-2">
                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.75rem;">Email Address</small>
                        <span class="fw-medium"><%= user.email || 'N/A' %></span>
                    </li>
                    <li class="list-group-item px-0 pb-2 pt-3">
                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.75rem;">Username</small>
                        <span class="fw-medium"><%= user.username || 'N/A' %></span>
                    </li>
                </ul>

                <div class="mt-4 pt-2">
                    <a href="/profile/password" class="btn btn-outline-primary w-100 fw-medium rounded-3">
                        <i class="bi bi-shield-lock me-2"></i> Change Password
                    </a>
                </div>
                
            </div>
        </div>
    </div>
</div>
