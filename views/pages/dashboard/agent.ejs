<% layout('layouts/main') -%>

<!-- Row 1: KPI Cards -->
<div class="row g-4 mb-4">
    <div class="col-12 col-md-4">
        <div class="card h-100 p-4 d-flex flex-row align-items-center gap-3">
            <div class="rounded bg-primary-light text-primary d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <i class="bi bi-receipt fs-4"></i>
            </div>
            <div>
                <p class="text-muted mb-1 small fw-medium">My Sales Today</p>
                <h4 class="mb-0 fw-bold"><%= stats.todaySaleCount %></h4>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-md-4">
        <div class="card h-100 p-4 d-flex flex-row align-items-center gap-3">
            <div class="rounded bg-success-light text-success d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <i class="bi bi-currency-dollar fs-4"></i>
            </div>
            <div>
                <p class="text-muted mb-1 small fw-medium">My Revenue Today</p>
                <h4 class="mb-0 fw-bold">$<%= stats.todayRevenue.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></h4>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-md-4">
        <div class="card h-100 p-4 d-flex flex-row align-items-center gap-3">
            <div class="rounded bg-warning-light text-warning d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <i class="bi bi-graph-up fs-4"></i>
            </div>
            <div>
                <p class="text-muted mb-1 small fw-medium">Total Sales This Month</p>
                <h4 class="mb-0 fw-bold">$<%= stats.monthSales.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></h4>
            </div>
        </div>
    </div>
</div>

<!-- Row 2: Large CTA -->
<div class="row mb-4">
    <div class="col-12">
        <a href="/sales/new" class="btn btn-primary w-100 fw-bold d-flex align-items-center justify-content-center gap-2 shadow-sm" style="height: 64px; font-size: 18px; border-radius: 12px;">
            <i class="bi bi-plus-circle-fill"></i>
            New Sale
        </a>
    </div>
</div>

<!-- Row 3: Data Table -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-transparent border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">My Recent Sales</h6>
            </div>
            <div class="card-body">
                <% if(recentSales && recentSales.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Time</th>
                                    <th>Items</th>
                                    <th>Total Amount</th>
                                    <th>Amount Paid</th>
                                    <th>Change</th>
                                    <th class="text-end">Receipt</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% recentSales.forEach(sale => { %>
                                <tr>
                                    <td class="text-muted"><%= new Date(sale.time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></td>
                                    <td><%= sale.items_count %></td>
                                    <td class="fw-bold text-success">$<%= sale.total.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                                    <td>$<%= sale.amount_paid.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                                    <td>$<%= sale.change_given.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                                    <td class="text-end">
                                        <a href="/receipts/<%= sale.sale_id %>" class="btn btn-sm btn-outline-secondary" title="View Receipt">
                                            <i class="bi bi-receipt"></i>
                                        </a>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                        <h6 class="fw-bold mb-1">No sales yet today</h6>
                        <p class="small">Click 'New Sale' to start your first transaction.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
