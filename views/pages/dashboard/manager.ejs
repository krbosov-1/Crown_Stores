<% layout('layouts/main') -%>

<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card h-100 p-4 d-flex flex-row align-items-center gap-3">
            <div class="rounded bg-primary-light text-primary d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <i class="bi bi-cart-check fs-4"></i>
            </div>
            <div>
                <p class="text-muted mb-1 small fw-medium">Today's Sales</p>
                <h4 class="mb-0 fw-bold"><%= typeof formatMoney === 'function' ? formatMoney(stats.todaySales) : stats.todaySales %></h4>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card h-100 p-4 d-flex flex-row align-items-center gap-3">
            <div class="rounded bg-success-light text-success d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <i class="bi bi-box fs-4"></i>
            </div>
            <div>
                <p class="text-muted mb-1 small fw-medium">Active Products</p>
                <h4 class="mb-0 fw-bold"><%= stats.activeProducts %></h4>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card h-100 p-4 d-flex flex-row align-items-center gap-3">
            <div class="rounded bg-warning-light text-warning d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <i class="bi bi-exclamation-triangle fs-4"></i>
            </div>
            <div>
                <p class="text-muted mb-1 small fw-medium">Low Stock Items</p>
                <h4 class="mb-0 fw-bold"><%= stats.lowStock %></h4>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card h-100 p-4 d-flex flex-row align-items-center gap-3">
            <div class="rounded bg-danger-light text-danger d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <i class="bi bi-x-octagon fs-4"></i>
            </div>
            <div>
                <p class="text-muted mb-1 small fw-medium">Out of Stock</p>
                <h4 class="mb-0 fw-bold"><%= stats.outOfStock %></h4>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-lg-7">
        <div class="card h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">Low Stock Alerts</h6>
            </div>
            <div class="card-body">
                <% if(lowStockList && lowStockList.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th>Current Qty</th>
                                    <th>Reorder Level</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% lowStockList.forEach(item => { %>
                                <tr>
                                    <td class="fw-medium"><%= item.name %></td>
                                    <td>
                                        <span class="badge bg-warning text-dark px-2 py-1"><%= item.qty %></span>
                                    </td>
                                    <td class="text-muted"><%= item.reorder_level %></td>
                                    <td>
                                        <a href="/products" class="btn btn-sm btn-outline-secondary">View</a>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-check-circle fs-3 text-success d-block mb-2"></i>
                        No low stock items.
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-lg-5">
        <div class="card h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h6 class="fw-bold mb-0 text-danger">Out of Stock (<%= outOfStockList.length %>)</h6>
            </div>
            <div class="card-body">
                <% if(outOfStockList && outOfStockList.length > 0) { %>
                    <ul class="list-group list-group-flush">
                        <% outOfStockList.forEach(item => { %>
                        <li class="list-group-item px-0 border-0 d-flex align-items-center gap-3 pb-2">
                            <span class="badge bg-danger rounded-circle p-1"><i class="bi bi-exclamation"></i></span>
                            <span class="fw-medium"><%= item.name %></span>
                        </li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <div class="text-center py-4">
                        <i class="bi bi-emoji-smile fs-3 text-success d-block mb-2"></i>
                        <span class="text-success fw-medium">All products in stock ✓</span>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">Recent Procurements</h6>
            </div>
            <div class="card-body">
                <% if(recentProcurements && recentProcurements.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Product</th>
                                    <th>Qty</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% recentProcurements.forEach(proc => { %>
                                <tr>
                                    <td class="text-muted small"><%= new Date(proc.date_received).toLocaleDateString() %></td>
                                    <td class="fw-medium"><%= proc.product_name %></td>
                                    <td><span class="badge bg-primary-light text-primary"><%= proc.quantity_received %> items</span></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-clock-history fs-3 d-block mb-2"></i>
                        No recent procurements.
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">Recent Sales</h6>
            </div>
            <div class="card-body">
                <% if(recentSales && recentSales.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Time</th>
                                    <th>Total</th>
                                    <th>Items</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% recentSales.forEach(sale => { %>
                                <tr>
                                    <td class="text-muted small"><%= new Date(sale.sale_date).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></td>
                                    <td class="fw-bold text-success"><%= typeof formatMoney === 'function' ? formatMoney(sale.total_amount) : sale.total_amount %></td>
                                    <td><%= sale.items_count %> item(s)</td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-clock-history fs-3 d-block mb-2"></i>
                        No recent sales today.
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-sm-6 col-lg-3">
        <a href="/sales/new" class="btn btn-primary w-100 py-3 fw-bold d-flex flex-column align-items-center gap-2">
            <i class="bi bi-plus-circle fs-4"></i>
            New Sale
        </a>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <a href="/procurement/new" class="btn btn-outline-primary w-100 py-3 fw-bold d-flex flex-column align-items-center gap-2 bg-white">
            <i class="bi bi-truck fs-4"></i>
            Procurement
        </a>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <a href="/products/new" class="btn btn-outline-primary w-100 py-3 fw-bold d-flex flex-column align-items-center gap-2 bg-white">
            <i class="bi bi-box-seam fs-4"></i>
            Add Product
        </a>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <a href="/reports" class="btn btn-outline-secondary w-100 py-3 fw-bold d-flex flex-column align-items-center gap-2 bg-white">
            <i class="bi bi-graph-up fs-4"></i>
            View Reports
        </a>
    </div>
</div>
