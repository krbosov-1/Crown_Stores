<% layout('layouts/main') -%>

<div class="card shadow-sm border-0">
    <div class="card-header bg-transparent border-0 pt-4 pb-2 px-4">
        <h5 class="fw-bold mb-0 text-dark">
            <i class="bi bi-box-seam text-primary me-2"></i> 
            <%= product ? 'Edit ProductDetails' : 'Add New Product' %>
        </h5>
    </div>
    <div class="card-body p-4">
        <form action="<%= product ? `/products/${product.id}/update` : '/products' %>" method="POST">
            
            <div class="row g-5">
                <!-- Left Column -->
                <div class="col-12 col-lg-6 border-end border-light pe-lg-5">
                    <h6 class="fw-bold mb-4 text-muted small text-uppercase">Basic Information</h6>
                    
                    <div class="form-floating mb-4 shadow-sm rounded">
                        <select class="form-select bg-light border-0 fw-medium" id="category_id" name="category_id" required>
                            <option value="" class="text-muted">Select Category</option>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat.id %>" <%= product && product.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                            <% }) %>
                        </select>
                        <label for="category_id" class="text-muted">Category <span class="text-danger">*</span></label>
                    </div>

                    <div class="form-floating mb-4 shadow-sm rounded">
                        <input type="text" class="form-control bg-light border-0 fw-bold text-dark" id="name" name="name" placeholder="Product Name" value="<%= product ? product.name : '' %>" required maxlength="255">
                        <label for="name" class="text-muted">Product Name <span class="text-danger">*</span></label>
                    </div>

                    <div class="form-floating mb-4 shadow-sm rounded">
                        <textarea class="form-control bg-light border-0" id="description" name="description" placeholder="Description" style="height: 140px"><%= product ? product.description : '' %></textarea>
                        <label for="description" class="text-muted">Description (Optional)</label>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="col-12 col-lg-6 ps-lg-4">
                    <h6 class="fw-bold mb-4 text-muted small text-uppercase">Pricing & Inventory</h6>
                    
                    <div class="row g-3 mb-2">
                        <div class="col-sm-6">
                            <div class="form-floating shadow-sm rounded">
                                <input type="number" step="0.01" class="form-control bg-light border-0 font-monospace text-muted" id="cost_price" name="cost_price" placeholder="Cost Price" value="<%= product ? product.cost_price : '' %>" required min="0">
                                <label for="cost_price" class="text-muted">Cost Price ($) <span class="text-danger">*</span></label>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-floating shadow-sm rounded">
                                <input type="number" step="0.01" class="form-control bg-light border-0 font-monospace fw-bold text-dark" id="selling_price" name="selling_price" placeholder="Selling Price" value="<%= product ? product.selling_price : '' %>" required min="0">
                                <label for="selling_price" class="text-muted">Selling Price ($) <span class="text-danger">*</span></label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-4 px-2 py-2 bg-light rounded d-flex align-items-center justify-content-between">
                        <span class="text-muted small fw-medium">Projected Margin</span>
                        <span id="profitDisplay" class="small fw-bold px-2 py-1 rounded border align-items-center d-flex gap-1">--</span>
                    </div>

                    <div class="form-floating mb-4 shadow-sm rounded">
                        <input type="number" class="form-control bg-light border-0 font-monospace" id="reorder_level" name="reorder_level" placeholder="Reorder Level" value="<%= product ? product.reorder_level : '10' %>" required min="0">
                        <label for="reorder_level" class="text-muted">Reorder Threshold <span class="text-danger">*</span></label>
                    </div>

                    <% if(product) { %>
                        <div class="form-check form-switch mt-4 bg-light p-3 rounded shadow-sm d-flex align-items-center gap-3">
                            <input class="form-check-input m-0 border-primary" type="checkbox" role="switch" id="status" name="status" <%= product.status === 'active' ? 'checked' : '' %> style="transform: scale(1.2);">
                            <label class="form-check-label user-select-none fw-medium text-dark m-0" for="status">Product is currently active in the system</label>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-end pt-4 mt-2 border-top border-light">
                <a href="/products" class="btn btn-light fw-medium px-4 py-2 text-dark border">Cancel</a>
                <button type="submit" class="btn btn-primary fw-medium px-4 py-2 shadow-sm"><i class="bi bi-sd-card me-2"></i><%= product ? 'Save Changes' : 'Create Product' %></button>
            </div>
        </form>
    </div>
</div>

<% block('scripts').append(`
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const costInput = document.getElementById('cost_price');
        const priceInput = document.getElementById('selling_price');
        const profitDisplay = document.getElementById('profitDisplay');

        function calculateProfit() {
            const cost = parseFloat(costInput.value) || 0;
            const price = parseFloat(priceInput.value) || 0;
            const profit = price - cost;
            let percent = 0;
            
            if (cost > 0) {
                percent = (profit / cost) * 100;
            } else if (price > 0 && cost === 0) {
               percent = 100; // 100% margin if cost is 0
            }
            
            if(isNaN(profit) || costInput.value === '' || priceInput.value === ''){
                 profitDisplay.innerHTML = '--';
                 profitDisplay.className = 'small fw-bold px-2 py-1 rounded border text-muted align-items-center d-flex gap-1';
                 return;
            }

            profitDisplay.innerHTML = \`<i class="bi \${profit >= 0 ? 'bi-arrow-up-right' : 'bi-arrow-down-right'}"></i> $\${profit.toFixed(2)} (\${percent.toFixed(1)}%)\`;
            
            if (profit > 0) {
                profitDisplay.className = 'small fw-bold px-2 py-1 rounded bg-success-light text-success border border-success-subtle align-items-center d-flex gap-1';
            } else if (profit < 0) {
                profitDisplay.className = 'small fw-bold px-2 py-1 rounded bg-danger-light text-danger border border-danger-subtle align-items-center d-flex gap-1';
            } else {
                profitDisplay.className = 'small fw-bold px-2 py-1 rounded border text-muted align-items-center d-flex gap-1';
            }
        }

        costInput.addEventListener('input', calculateProfit);
        priceInput.addEventListener('input', calculateProfit);
        
        // Initial calculation if editing
        calculateProfit();
    });
</script>
`) %>
