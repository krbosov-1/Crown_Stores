<% layout('layouts/main') -%>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
        <h4 class="fw-bold mb-0 text-dark"><%= product.name %></h4>
        <% if(product.status === 'active') { %>
            <span class="badge bg-success-light text-success px-2 py-1 fw-bold">Active</span>
        <% } else { %>
            <span class="badge bg-danger-light text-danger px-2 py-1 fw-bold">Inactive</span>
        <% } %>
    </div>
    <div class="d-flex gap-2">
        <a href="/products" class="btn btn-outline-dark fw-medium bg-white shadow-sm"><i class="bi bi-arrow-left me-2"></i> Back to products</a>
        <a href="/products/<%= product.id %>/edit" class="btn btn-primary fw-medium shadow-sm"><i class="bi bi-pencil me-2"></i> Edit Product</a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <div class="row g-4 align-items-end">
            <!-- Details List -->
            <div class="col-12">
                <dl class="row mb-0 g-4">
                    <div class="col-12 col-sm-6 col-lg-3">
                        <dt class="text-muted small fw-medium mb-1 text-uppercase">Category</dt>
                        <dd class="fw-bold text-dark fs-5 mb-0"><%= product.category_name || 'Uncategorized' %></dd>
                    </div>
                    <div class="col-12 col-sm-6 col-lg-3">
                        <dt class="text-muted small fw-medium mb-1 text-uppercase">Current Stock</dt>
                        <dd class="fw-bold fs-5 mb-0 d-flex align-items-center gap-2 <%= product.stock < product.reorder_level ? 'text-danger' : 'text-success' %>">
                            <i class="bi <%= product.stock < product.reorder_level ? 'bi-exclamation-circle' : 'bi-check-circle' %>"></i>
                            <%= product.stock || 0 %> <span class="fs-6 fw-normal text-muted ms-1">Units</span>
                        </dd>
                    </div>
                    <div class="col-12 col-sm-6 col-lg-3">
                        <dt class="text-muted small fw-medium mb-1 text-uppercase">Cost Price</dt>
                        <dd class="fw-bold text-dark font-monospace fs-5 mb-0">$<%= parseFloat(product.cost_price).toFixed(2) %></dd>
                    </div>
                    <div class="col-12 col-sm-6 col-lg-3">
                        <dt class="text-muted small fw-medium mb-1 text-uppercase">Selling Price</dt>
                        <dd class="fw-bold text-dark font-monospace fs-5 mb-0">$<%= parseFloat(product.selling_price).toFixed(2) %></dd>
                    </div>
                    <div class="col-12 mt-4 pt-3 border-top border-light">
                        <dt class="text-muted small fw-medium mb-2 text-uppercase">Product Description</dt>
                        <dd class="mb-0 text-dark"><%= product.description || 'No description provided.' %></dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-pills mb-3 gap-2" id="myTab" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active rounded-pill fw-medium px-4 shadow-sm" id="barcodes-tab" data-bs-toggle="tab" data-bs-target="#barcodes-tab-pane" type="button" role="tab" aria-controls="barcodes-tab-pane" aria-selected="true"><i class="bi bi-upc-scan me-2"></i>Barcodes</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link rounded-pill fw-medium px-4 bg-white border border-light text-muted" id="sales-tab" data-bs-toggle="tab" data-bs-target="#sales-tab-pane" type="button" role="tab" aria-controls="sales-tab-pane" aria-selected="false"><i class="bi bi-graph-up me-2"></i>Sales History</button>
    </li>
</ul>

<div class="tab-content" id="myTabContent">
    <!-- Barcodes Tab -->
    <div class="tab-pane fade show active" id="barcodes-tab-pane" role="tabpanel" aria-labelledby="barcodes-tab" tabindex="0">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-4 pb-2 px-4 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0 text-dark">Linked Barcodes</h6>
                <a href="/products/<%= product.id %>/barcodes" class="btn btn-sm btn-dark px-3 fw-medium rounded-pill shadow-sm"><i class="bi bi-gear me-2"></i>Manage Barcodes</a>
            </div>
            <div class="card-body p-0">
                <% if(barcodes && barcodes.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4 py-3">Barcode Number</th>
                                    <th class="py-3">Status</th>
                                    <th class="py-3 text-end pe-4">Assigned On</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% barcodes.forEach(b => { %>
                                    <tr>
                                        <td class="ps-4 fw-bold font-monospace text-dark fs-5"><%= b.barcode_number %></td>
                                        <td>
                                            <% if(b.status === 'active') { %>
                                                <span class="badge bg-success-light text-success fw-medium">Active</span>
                                            <% } else { %>
                                                <span class="badge bg-danger-light text-danger fw-medium">Inactive</span>
                                            <% } %>
                                        </td>
                                        <td class="text-muted small text-end pe-4 fw-medium"><%= new Date(b.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <div class="bg-light rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 64px; height: 64px;">
                            <i class="bi bi-upc-scan fs-3 text-muted"></i>
                        </div>
                        <h6 class="fw-bold text-dark">No Barcodes found</h6>
                        <p class="small text-muted mb-3">Link barcodes to scan this product at POS.</p>
                        <a href="/products/<%= product.id %>/barcodes" class="btn btn-outline-dark btn-sm fw-medium px-4 rounded-pill">Add Barcode Now</a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    
    <!-- Sales Tab -->
    <div class="tab-pane fade" id="sales-tab-pane" role="tabpanel" aria-labelledby="sales-tab" tabindex="0">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-4 pb-2 px-4">
                <h6 class="fw-bold mb-0 text-dark">Recent Sales (Last 20)</h6>
            </div>
            <div class="card-body p-0">
                <% if(salesHistory && salesHistory.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4 py-3">Date</th>
                                    <th class="py-3">Quantity</th>
                                    <th class="py-3">Unit Price</th>
                                    <th class="py-3">Subtotal</th>
                                    <th class="py-3 text-end pe-4">Agent</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% salesHistory.forEach(s => { %>
                                    <tr>
                                        <td class="ps-4 text-muted small fw-medium">
                                            <%= new Date(s.sale_date).toLocaleDateString(undefined, {month:'short', day:'numeric'}) %> 
                                            <span class="text-black-50 ms-1"><%= new Date(s.sale_date).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                                        </td>
                                        <td class="fw-bold text-dark"><span class="bg-light px-2 py-1 rounded text-muted"><%= s.quantity %></span></td>
                                        <td class="font-monospace text-muted">$<%= parseFloat(s.unit_price).toFixed(2) %></td>
                                        <td class="fw-bold font-monospace text-dark">$<%= parseFloat(s.subtotal).toFixed(2) %></td>
                                        <td class="text-end pe-4 text-muted fw-medium d-flex align-items-center justify-content-end gap-2">
                                            <i class="bi bi-person-badge"></i>
                                            <%= s.agent_name %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <div class="bg-light rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 64px; height: 64px;">
                            <i class="bi bi-cart-x fs-3 text-muted"></i>
                        </div>
                        <h6 class="fw-bold text-dark">No Sales History</h6>
                        <p class="small text-muted mb-0">This product hasn't been sold yet.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<% block('scripts').append(`
<script>
    // Make tabs look active/inactive aesthetically beyond just bootstrap logic
    const triggerTabList = document.querySelectorAll('#myTab button')
    triggerTabList.forEach(triggerEl => {
        const tabTrigger = new bootstrap.Tab(triggerEl)
        triggerEl.addEventListener('click', event => {
            event.preventDefault()
            tabTrigger.show()
            
            // Restyle all pills to inactive
            triggerTabList.forEach(el => {
                el.classList.remove('shadow-sm')
                el.classList.add('bg-white', 'border', 'border-light', 'text-muted')
            })
            // Style active
            event.target.classList.add('shadow-sm')
            event.target.classList.remove('bg-white', 'border', 'border-light', 'text-muted')
        })
    })
</script>
`) %>
