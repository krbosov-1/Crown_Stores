<% layout('layouts/main') -%>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Products</h4>
    <a href="/products/new" class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-sm fw-medium">
        <i class="bi bi-plus-lg"></i> Add Product
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <form method="GET" action="/products" class="row g-3">
            <div class="col-12 col-md-4">
                <input type="text" class="form-control bg-light border-0" name="search" placeholder="Search by name..." value="<%= filters.search || '' %>">
            </div>
            <div class="col-12 col-md-3">
                <select class="form-select bg-light border-0" name="category_id">
                    <option value="">All Categories</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>" <%= filters.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <select class="form-select bg-light border-0" name="status">
                    <option value="">All Statuses</option>
                    <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
                    <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                </select>
            </div>
            <div class="col-12 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-dark w-100 fw-medium shadow-sm">Filter</button>
                <a href="/products" class="btn border border-light text-muted w-100 bg-white" title="Clear Filters"><i class="bi bi-eraser me-1"></i> Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3">Name</th>
                        <th class="py-3">Category</th>
                        <th class="py-3">Cost</th>
                        <th class="py-3">Price</th>
                        <th class="py-3">Stock</th>
                        <th class="py-3">Reorder</th>
                        <th class="py-3">Status</th>
                        <th class="text-end pe-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(products && products.length > 0) { %>
                        <% products.forEach(p => { %>
                            <tr>
                                <td class="ps-4 fw-bold">
                                    <a href="/products/<%= p.id %>" class="text-decoration-none text-dark d-flex align-items-center gap-2">
                                        <div class="bg-light rounded p-2 text-muted">
                                            <i class="bi bi-box"></i>
                                        </div>
                                        <%= p.name %>
                                    </a>
                                </td>
                                <td><%= p.category_name || 'Uncategorized' %></td>
                                <td class="text-muted">$<%= parseFloat(p.cost_price).toFixed(2) %></td>
                                <td class="fw-medium text-success">$<%= parseFloat(p.selling_price).toFixed(2) %></td>
                                <td>
                                    <% 
                                        let stockClass = "success";
                                        let stockBadge = "";
                                        let stockVal = p.stock || 0;
                                        if (stockVal === 0) {
                                            stockClass = "danger";
                                            stockBadge = "bg-danger";
                                        } else if (stockVal < p.reorder_level) {
                                            stockClass = "warning";
                                            stockBadge = "bg-warning text-dark";
                                        } else {
                                            stockBadge = "bg-success-light text-success border border-success-subtle";
                                        }
                                    %>
                                    <span class="badge <%= stockBadge %> px-2 py-1"><%= stockVal %></span>
                                </td>
                                <td class="text-muted"><%= p.reorder_level %></td>
                                <td>
                                    <% if(p.status === 'active') { %>
                                        <span class="badge bg-success-light text-success px-2 py-1">Active</span>
                                    <% } else { %>
                                        <span class="badge bg-danger-light text-danger px-2 py-1">Inactive</span>
                                    <% } %>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a href="/products/<%= p.id %>/edit" class="btn btn-sm btn-light border-0" data-bs-toggle="tooltip" title="Edit">
                                            <i class="bi bi-pencil text-primary"></i>
                                        </a>
                                        <a href="/products/<%= p.id %>/barcodes" class="btn btn-sm btn-light border-0 border-start border-white" data-bs-toggle="tooltip" title="Barcodes">
                                            <i class="bi bi-upc-scan text-dark"></i>
                                        </a>
                                        <form action="/products/<%= p.id %>/toggle" method="POST" class="m-0 border-start border-white">
                                            <button type="submit" class="btn btn-sm btn-light border-0 text-<%= p.status === 'active' ? 'danger' : 'success' %>" data-bs-toggle="tooltip" title="<%= p.status === 'active' ? 'Deactivate' : 'Activate' %>">
                                                <i class="bi <%= p.status === 'active' ? 'bi-lock' : 'bi-unlock' %>"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <div class="bg-light rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 64px; height: 64px;">
                                    <i class="bi bi-inbox fs-2"></i>
                                </div>
                                <h6 class="fw-bold text-dark">No products found</h6>
                                <p class="small mb-0">Try adjusting your filters or add a new product.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
    
    <% if(pagination && pagination.totalPages > 1) { %>
        <div class="card-footer bg-transparent border-top p-4 d-flex justify-content-between align-items-center">
            <span class="text-muted small fw-medium">Showing page <%= pagination.page %> of <%= pagination.totalPages %> (<%= pagination.totalProducts %> total items)</span>
            <%- include('../../partials/pagination', { pagination: pagination, baseUrl: '/products', queryParams: filters }) %>
        </div>
    <% } %>
</div>

<% block('scripts').append(`
<script>
    // Initialize tooltips
    const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]')
    const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl))
</script>
`) %>
