<% layout('layouts/main') -%>

<div class="mb-4">
    <div class="d-flex align-items-center gap-2 mb-1">
        <a href="/inventory" class="text-muted text-decoration-none small fw-medium"><i class="bi bi-arrow-left me-1"></i> Back to Inventory</a>
    </div>
    <h4 class="fw-bold mb-0 text-dark">Movement History</h4>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <form method="GET" action="/inventory/history" class="row g-3">
            <div class="col-12 col-md-3">
                <label class="form-label text-muted small fw-bold text-uppercase mb-1">Search Product</label>
                <input type="text" class="form-control bg-light border-0" name="search" placeholder="Type name..." value="<%= filters.search || '' %>">
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label text-muted small fw-bold text-uppercase mb-1">Movement Type</label>
                <select name="movement_type" class="form-select bg-light border-0">
                    <option value="">All Types</option>
                    <option value="Procurement" <%= filters.movement_type === 'Procurement' ? 'selected' : '' %>>Procurement (In)</option>
                    <option value="Sale" <%= filters.movement_type === 'Sale' ? 'selected' : '' %>>Sale (Out)</option>
                    <option value="Adjustment" <%= filters.movement_type === 'Adjustment' ? 'selected' : '' %>>Adjustment</option>
                </select>
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label text-muted small fw-bold text-uppercase mb-1">From Date</label>
                <input type="date" class="form-control bg-light border-0" name="date_from" value="<%= filters.date_from || '' %>">
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label text-muted small fw-bold text-uppercase mb-1">To Date</label>
                <input type="date" class="form-control bg-light border-0" name="date_to" value="<%= filters.date_to || '' %>">
            </div>
            <div class="col-12 col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-dark w-100 fw-medium shadow-sm">Apply</button>
                <a href="/inventory/history" class="btn border border-light text-muted bg-white shadow-sm px-3" title="Clear Filters"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small text-muted fw-bold">Date & Time</th>
                        <th class="py-3 text-uppercase small text-muted fw-bold">Movement Type</th>
                        <th class="py-3 text-uppercase small text-muted fw-bold">Product</th>
                        <th class="py-3 text-uppercase small text-muted fw-bold text-end">Change</th>
                        <th class="py-3 text-uppercase small text-muted fw-bold">Reason / Details</th>
                        <th class="py-3 text-uppercase small text-muted fw-bold pe-4">Performed By</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(history && history.length > 0) { %>
                        <% history.forEach(item => { %>
                            <tr>
                                <td class="ps-4 text-muted small fw-medium">
                                    <div class="d-flex flex-column">
                                        <span class="text-dark"><%= new Date(item.movement_date).toLocaleDateString() %></span>
                                        <span style="font-size:0.75rem;"><%= new Date(item.movement_date).toLocaleTimeString() %></span>
                                    </div>
                                </td>
                                <td>
                                    <% if(item.movement_type === 'Procurement') { %>
                                        <span class="badge bg-success-light text-success border border-success-subtle px-2 py-1"><i class="bi bi-box-arrow-in-right me-1"></i> Procurement</span>
                                    <% } else if(item.movement_type === 'Sale') { %>
                                        <span class="badge bg-danger-light text-danger border border-danger-subtle px-2 py-1"><i class="bi bi-cart-check me-1"></i> Sale</span>
                                    <% } else { %>
                                        <span class="badge bg-warning-light text-warning border border-warning-subtle px-2 py-1"><i class="bi bi-sliders me-1"></i> Adjustment</span>
                                    <% } %>
                                </td>
                                <td class="fw-bold text-dark">
                                    <a href="/products/<%= item.product_id %>" class="text-decoration-none text-dark d-flex align-items-center gap-2">
                                        <div class="bg-light rounded p-2 text-muted" style="width: 32px; height: 32px; display: inline-flex; align-items:center; justify-content:center;">
                                            <i class="bi bi-box"></i>
                                        </div>
                                        <%= item.product_name %>
                                    </a>
                                </td>
                                <td class="text-end">
                                    <% if(item.change_qty > 0) { %>
                                        <span class="badge bg-success rounded-pill fw-bold fs-6"> +<%= item.change_qty %> </span>
                                    <% } else { %>
                                        <span class="badge bg-danger rounded-pill fw-bold fs-6"> <%= item.change_qty %> </span>
                                    <% } %>
                                </td>
                                <td>
                                    <span class="text-muted small fw-medium d-inline-block text-truncate" style="max-width: 250px;" title="<%= item.reason %>">
                                        <%= item.reason || 'N/A' %>
                                    </span>
                                </td>
                                <td class="pe-4 text-muted small fw-medium">
                                    <i class="bi bi-person me-1"></i><%= item.performed_by || 'System' %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <div class="bg-light rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow-sm border" style="width: 64px; height: 64px;">
                                    <i class="bi bi-clock-history fs-2"></i>
                                </div>
                                <h6 class="fw-bold text-dark">No movements found</h6>
                                <p class="small mb-0">Adjust your filters to see more results.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
    <% if(pagination && pagination.totalPages > 1) { %>
        <div class="card-footer bg-transparent border-top p-4 d-flex justify-content-between align-items-center">
            <span class="text-muted small fw-medium">Showing page <%= pagination.page %> of <%= pagination.totalPages %></span>
            <%- include('../../partials/pagination', { pagination: pagination, baseUrl: '/inventory/history', queryParams: filters }) %>
        </div>
    <% } %>
</div>
