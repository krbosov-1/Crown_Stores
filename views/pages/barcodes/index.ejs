<% layout('layouts/main') -%>

<div class="mb-4">
    <div class="d-flex align-items-center gap-2 mb-1">
        <a href="/products/<%= product.id %>" class="text-muted text-decoration-none small fw-medium"><i class="bi bi-arrow-left me-1"></i> Back</a>
    </div>
    <h4 class="fw-bold mb-1 text-dark d-flex align-items-center gap-2">
        <i class="bi bi-upc-scan text-primary"></i> Barcode Management
    </h4>
    <p class="text-muted mb-0 fw-medium">For <span class="fw-bold text-dark"><%= product.name %></span></p>
</div>

<!-- Product Context Card -->
<div class="card mb-4 bg-primary-light border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="row g-4 align-items-center">
            <div class="col-12 col-md-4 border-end border-primary border-opacity-10">
                <span class="text-primary fw-bold small text-uppercase opacity-75">Category</span>
                <p class="mb-0 fw-bold text-primary fs-5 mt-1 d-flex align-items-center gap-2">
                    <i class="bi bi-tag text-primary opacity-75"></i> <%= product.category_name || 'Uncategorized' %>
                </p>
            </div>
            <div class="col-12 col-md-4">
                <span class="text-primary fw-bold small text-uppercase opacity-75">Current Stock</span>
                <p class="mb-0 fw-bold fs-5 mt-1 d-flex align-items-center gap-2 <%= product.stock < product.reorder_level ? 'text-danger' : 'text-primary' %>">
                    <i class="bi <%= product.stock < product.reorder_level ? 'bi-exclamation-triangle' : 'bi-box-seam' %>"></i> 
                    <%= product.stock || 0 %> Units
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Add Barcode Form -->
<div class="card mb-5 border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-4 bg-white">
        <h6 class="fw-bold text-dark mb-3"><i class="bi bi-plus-circle me-2 text-primary"></i>Register New Barcode</h6>
        <form action="/products/<%= product.id %>/barcodes" method="POST" class="d-flex align-items-center gap-3">
            <div class="flex-grow-1 position-relative">
                <label for="barcode_number" class="visually-hidden">Barcode Number</label>
                <div class="input-group input-group-lg shadow-sm rounded px-1 py-1 border">
                    <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-upc"></i></span>
                    <input type="text" class="form-control border-0 fw-monospace text-dark fw-bold fs-5 shadow-none" id="barcode_number" name="barcode_number" placeholder="Scan or type barcode number here..." required autofocus>
                </div>
            </div>
            <button type="submit" class="btn btn-dark btn-lg px-4 fw-bold shadow-sm rounded">
                Add to Product
            </button>
        </form>
    </div>
</div>

<!-- Barcodes Table -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
        <h6 class="fw-bold mb-0 text-dark">Registered Barcodes List</h6>
    </div>
    <div class="card-body p-0 mt-3">
        <% if(barcodes && barcodes.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small text-muted fw-bold">Barcode Identifier</th>
                            <th class="py-3 text-uppercase small text-muted fw-bold">Status</th>
                            <th class="py-3 text-uppercase small text-muted fw-bold">Registration Date</th>
                            <th class="text-end pe-4 py-3 text-uppercase small text-muted fw-bold">Management</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% barcodes.forEach(b => { %>
                            <tr>
                                <td class="ps-4 fw-bold font-monospace fs-4 text-dark letter-spacing-1">
                                    <i class="bi bi-upc me-2 text-muted fs-5"></i><%= b.barcode_number %>
                                </td>
                                <td>
                                    <% if(b.status === 'active') { %>
                                        <span class="badge bg-success-light text-success px-3 py-2 fw-medium rounded-pill border border-success-subtle">Active</span>
                                    <% } else { %>
                                        <span class="badge bg-danger-light text-danger px-3 py-2 fw-medium rounded-pill border border-danger-subtle">Inactive</span>
                                    <% } %>
                                </td>
                                <td class="text-muted fw-medium font-monospace">
                                    <%= new Date(b.created_at).toLocaleDateString(undefined, {year: 'numeric', month: 'short', day: '2-digit'}) %>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <form action="/products/<%= product.id %>/barcodes/<%= b.id %>/toggle" method="POST" class="m-0">
                                            <button type="submit" class="btn btn-light border-0 shadow-sm text-<%= b.status === 'active' ? 'warning' : 'success' %>" data-bs-toggle="tooltip" title="<%= b.status === 'active' ? 'Deactivate Barcode' : 'Activate Barcode' %>">
                                                <i class="bi <%= b.status === 'active' ? 'bi-pause-circle-fill' : 'bi-play-circle-fill' %> fs-5"></i>
                                            </button>
                                        </form>
                                        <button type="button" class="btn btn-light border-0 shadow-sm text-danger" data-bs-toggle="modal" data-bs-target="#deleteModal<%= b.id %>" title="Delete">
                                            <i class="bi bi-trash3-fill fs-5"></i>
                                        </button>
                                    </div>

                                    <!-- Delete Modal -->
                                    <div class="modal fade text-start" id="deleteModal<%= b.id %>" tabindex="-1" aria-labelledby="deleteModalLabel<%= b.id %>" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                                                <div class="modal-header border-0 bg-danger-light pt-4 pb-4 px-4">
                                                    <h5 class="modal-title fw-bold text-danger d-flex align-items-center gap-2" id="deleteModalLabel<%= b.id %>">
                                                        <i class="bi bi-exclamation-diamond-fill fs-4"></i>
                                                        Confirm Permanent Deletion
                                                    </h5>
                                                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body p-4 text-dark fs-6">
                                                    Are you absolutely sure you want to permanently delete the barcode <strong class="font-monospace fs-5 px-2 py-1 bg-light rounded border text-danger"><%= b.barcode_number %></strong>?<br><br>
                                                    <span class="text-muted small">This action cannot be undone and will prevent this item from being scanned using this code.</span>
                                                </div>
                                                <div class="modal-footer border-0 p-4 bg-light">
                                                    <button type="button" class="btn btn-white border fw-bold px-4 rounded shadow-sm text-muted" data-bs-dismiss="modal">Cancel</button>
                                                    <form action="/products/<%= product.id %>/barcodes/<%= b.id %>/delete" method="POST" class="m-0">
                                                        <button type="submit" class="btn btn-danger fw-bold px-4 rounded shadow-sm">Yes, Terminate Barcode</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-5 text-muted bg-light mx-4 mb-4 rounded-4 border border-dashed">
                <div class="bg-white rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow-sm border" style="width: 72px; height: 72px;">
                    <i class="bi bi-upc fs-2 text-dark"></i>
                </div>
                <h6 class="fw-bold text-dark fs-5">No Barcodes Available</h6>
                <p class="text-muted small max-w-sm mx-auto mb-0">Use the input field above or scan a barcode with your reader to link it to this product.</p>
            </div>
        <% } %>
    </div>
</div>

<% block('scripts').append(`
<script>
    // Focus the input when modal closes or page loads
    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('barcode_number').focus();
    });
    
    // Initialize tooltips
    const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]')
    const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl))
</script>
`) %>
