<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>500 Server Error — CSRMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { display: flex; align-items: center; justify-content: center; height: 100vh; background-color: var(--color-bg); }
        .error-card { text-align: center; max-width: 500px; padding: 3rem; background: var(--color-surface); border-radius: var(--border-radius-lg); box-shadow: var(--box-shadow-sm); border: 1px solid var(--color-border); }
        .error-code { font-size: 8rem; font-weight: 700; color: var(--color-danger); line-height: 1; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <div class="error-card">
        <div class="error-code">500</div>
        <h1 class="h3 fw-bold mb-3" style="color: var(--color-text);">Something went wrong.</h1>
        <p class="text-muted mb-4">Our team has been notified of the issue. Please try again later.</p>
        <a href="/dashboard" class="btn btn-primary px-4 py-2" style="border-radius: var(--border-radius-md);">Go to Dashboard</a>
    </div>
</body>
</html>
