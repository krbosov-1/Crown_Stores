<% layout('layouts/main') -%>

<div class="mb-4">
    <div class="d-flex align-items-center gap-2 mb-1">
        <a href="/procurement" class="text-muted text-decoration-none small fw-medium"><i class="bi bi-arrow-left me-1"></i> Back</a>
    </div>
    <h4 class="fw-bold mb-0 text-dark">Record Procurement</h4>
</div>

<div class="row">
    <!-- Visual Steps Indicator -->
    <div class="col-12 col-xl-10 mx-auto mb-4 d-none d-md-block">
        <div class="d-flex justify-content-between align-items-center position-relative">
            <div class="progress position-absolute top-50 start-0 w-100 translate-middle-y z-0" style="height: 4px; border-radius: 4px;">
                <div id="stepProgress" class="progress-bar bg-primary" role="progressbar" style="width: 50%" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
            
            <div class="d-flex flex-column align-items-center position-relative z-1">
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center shadow-sm border border-3 border-white" style="width: 48px; height: 48px; font-weight: bold;">1</div>
                <span class="mt-2 small fw-bold text-dark">Find Product</span>
            </div>
            
            <div class="d-flex flex-column align-items-center position-relative z-1">
                <div id="step2Indicator" class="rounded-circle bg-light text-muted d-flex align-items-center justify-content-center shadow-sm border border-3 border-white transition-all" style="width: 48px; height: 48px; font-weight: bold;">2</div>
                <span id="step2Label" class="mt-2 small fw-bold text-muted transition-all">Enter Details</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-10 mx-auto">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-0">
                
                <!-- STEP 1: Find Product -->
                <div id="step1" class="p-4 p-md-5 bg-white">
                    <h5 class="fw-bold text-dark mb-4"><i class="bi bi-search me-2 text-primary"></i>Step 1: Locate Product</h5>
                    
                    <div class="position-relative mb-4">
                        <div class="input-group input-group-lg shadow-sm rounded-pill px-2 py-1 border overflow-hidden">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-upc-scan fs-5"></i></span>
                            <input type="text" class="form-control border-0 fw-medium shadow-none fs-5 bg-transparent" id="searchInput" placeholder="Search by product name or barcode..." autocomplete="off">
                            <button class="btn btn-light rounded-pill border-0 me-1 d-none" type="button" id="clearSearchBtn"><i class="bi bi-x-lg"></i></button>
                        </div>
                        <div id="searchSpinner" class="position-absolute end-0 top-50 translate-middle-y me-4 d-none">
                            <div class="spinner-border spinner-border-sm text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Search Results Area -->
                    <div id="searchResults" class="row g-3">
                        <div class="col-12 py-5 text-center text-muted border border-dashed rounded-3 bg-light">
                            <div class="bg-white rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow-sm border" style="width: 56px; height: 56px;">
                                <i class="bi bi-hand-index-thumb fs-3"></i>
                            </div>
                            <h6 class="fw-bold mb-1 text-dark">Ready to search</h6>
                            <p class="small mb-0">Type at least 2 characters or scan a barcode.</p>
                        </div>
                    </div>
                </div>

                <!-- STEP 2: Enter Details -->
                <div id="step2" class="p-4 p-md-5 bg-light d-none border-top">
                    <h5 class="fw-bold text-dark mb-4 d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-pencil-square me-2 text-primary"></i>Step 2: Enter Procurement Details</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill shadow-sm" id="changeProductBtn">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Change Product
                        </button>
                    </h5>
                    
                    <!-- Selected Product Card -->
                    <div class="card mb-4 border-0 shadow-sm bg-primary-light">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="badge bg-white text-primary border border-primary-subtle rounded-pill px-3 py-1" id="selCategory">Category</span>
                                <span class="small fw-bold text-muted text-uppercase">Current Stock</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-end mt-2">
                                <h4 class="fw-bold mb-0 text-dark" id="selName">Product Name</h4>
                                <h3 class="fw-bold text-primary mb-0 d-flex align-items-center gap-2"><i class="bi bi-box"></i> <span id="selStock">0</span></h3>
                            </div>
                        </div>
                    </div>

                    <form action="/procurement" method="POST" id="procurementForm">
                        <input type="hidden" name="product_id" id="product_id">
                        
                        <div class="row g-4 mb-4">
                            <div class="col-12 col-md-6">
                                <div class="form-floating shadow-sm rounded bg-white">
                                    <input type="text" class="form-control border-0 fw-bold bg-transparent" id="supplier_name" name="supplier_name" placeholder="Supplier Name" required>
                                    <label for="supplier_name" class="text-muted">Supplier / Vendor Name <span class="text-danger">*</span></label>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="form-floating shadow-sm rounded bg-white">
                                    <input type="date" class="form-control border-0 bg-transparent text-muted fw-medium" id="received_date" name="received_date" value="<%= new Date().toISOString().split('T')[0] %>" required>
                                    <label for="received_date" class="text-muted">Date Received <span class="text-danger">*</span></label>
                                </div>
                            </div>
                            
                            <div class="col-12 col-md-6">
                                <div class="form-floating shadow-sm rounded bg-white position-relative">
                                    <input type="number" class="form-control border-0 fw-bold fs-5 bg-transparent font-monospace" id="quantity" name="quantity" placeholder="Units Received" required min="1">
                                    <label for="quantity" class="text-muted">Quantity Received <span class="text-danger">*</span></label>
                                    <span class="position-absolute end-0 top-50 translate-middle-y me-3 text-muted small fw-bold">UNITS</span>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="form-floating shadow-sm rounded bg-white position-relative">
                                    <input type="number" step="0.01" class="form-control border-0 fw-bold fs-5 bg-transparent text-success font-monospace" id="unit_cost" name="unit_cost" placeholder="Cost per Unit" required min="0">
                                    <label for="unit_cost" class="text-muted">Cost per Unit <span class="text-danger">*</span></label>
                                    <span class="position-absolute end-0 top-50 translate-middle-y me-3 text-muted small fw-bold">USD</span>
                                </div>
                            </div>
                        </div>

                        <!-- Total Computed Alert -->
                        <div class="alert alert-success d-flex align-items-center p-3 mb-4 border-0 shadow-sm rounded d-none" id="totalPreview">
                            <div class="bg-white rounded-circle p-2 me-3 d-flex align-items-center justify-content-center text-success shadow-sm">
                                <i class="bi bi-info-circle-fill"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">Total Procurement Value:</h6>
                                <span class="small font-monospace fw-medium" id="totalValueSpan">$0.00</span>
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm py-3 fw-bold rounded-3">
                                <i class="bi bi-check-circle me-2"></i> Record Procurement
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

<% block('scripts').append(`
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('searchInput');
        const searchResults = document.getElementById('searchResults');
        const searchSpinner = document.getElementById('searchSpinner');
        const clearSearchBtn = document.getElementById('clearSearchBtn');
        
        const step1 = document.getElementById('step1');
        const step2 = document.getElementById('step2');
        const stepProgress = document.getElementById('stepProgress');
        const step2Indicator = document.getElementById('step2Indicator');
        const step2Label = document.getElementById('step2Label');
        
        const changeProductBtn = document.getElementById('changeProductBtn');
        
        // Form inputs
        const productIdInput = document.getElementById('product_id');
        const quantityInput = document.getElementById('quantity');
        const unitCostInput = document.getElementById('unit_cost');
        const totalPreview = document.getElementById('totalPreview');
        const totalValueSpan = document.getElementById('totalValueSpan');

        let debounceTimer;

        // AJAX Search
        searchInput.addEventListener('input', () => {
            const query = searchInput.value.trim();
            
            if (query.length > 0) {
                clearSearchBtn.classList.remove('d-none');
            } else {
                clearSearchBtn.classList.add('d-none');
            }

            clearTimeout(debounceTimer);
            if (query.length < 2) {
                searchResults.innerHTML = \`
                    <div class="col-12 py-5 text-center text-muted border border-dashed rounded-3 bg-light">
                        <div class="bg-white rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow-sm border" style="width: 56px; height: 56px;">
                            <i class="bi bi-hand-index-thumb fs-3"></i>
                        </div>
                        <h6 class="fw-bold mb-1 text-dark">Ready to search</h6>
                        <p class="small mb-0">Type at least 2 characters or scan a barcode.</p>
                    </div>\`;
                return;
            }

            searchSpinner.classList.remove('d-none');
            debounceTimer = setTimeout(() => {
                fetch(\`/procurement/api/search?q=\${encodeURIComponent(query)}\`)
                    .then(res => res.json())
                    .then(data => {
                        searchSpinner.classList.add('d-none');
                        renderResults(data);
                    })
                    .catch(err => {
                        console.error(err);
                        searchSpinner.classList.add('d-none');
                        searchResults.innerHTML = '<div class="col-12"><div class="alert alert-danger">Error searching products.</div></div>';
                    });
            }, 400);
        });

        clearSearchBtn.addEventListener('click', () => {
            searchInput.value = '';
            searchInput.dispatchEvent(new Event('input'));
            searchInput.focus();
        });

        function renderResults(products) {
            if (products.length === 0) {
                searchResults.innerHTML = \`
                    <div class="col-12 py-5 text-center text-muted border border-dashed rounded-3 bg-light">
                        <div class="bg-white rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow-sm border" style="width: 56px; height: 56px;">
                            <i class="bi bi-search fs-3"></i>
                        </div>
                        <h6 class="fw-bold mb-1 text-dark">No products found</h6>
                        <p class="small mb-0">Try a different search term or add the product first.</p>
                    </div>\`;
                return;
            }

            searchResults.innerHTML = '';
            products.forEach(p => {
                const col = document.createElement('div');
                col.className = 'col-12 col-md-6 mb-3';
                const stock = p.stock || 0;
                const stockBadgeClass = stock > 0 ? 'bg-success-light text-success border border-success-subtle' : 'bg-danger-light text-danger border border-danger-subtle';
                
                col.innerHTML = \`
                    <div class="card h-100 border rounded-3 product-card shadow-sm" style="cursor: pointer; transition: all 0.2s;" data-id="\${p.id}" data-name="\${p.name.replace(/"/g, '&quot;')}" data-category="\${p.category_name || 'Uncategorized'}" data-stock="\${stock}" data-cost="\${p.cost_price}">
                        <div class="card-body p-3 d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="fw-bold text-dark mb-1">\${p.name}</h6>
                                <span class="badge bg-light text-muted border small">\${p.category_name || 'Uncategorized'}</span>
                            </div>
                            <div class="text-end">
                                <span class="badge \${stockBadgeClass} px-2 py-1 rounded-pill mb-1 d-block"><i class="bi bi-box me-1"></i> Stock: \${stock}</span>
                                <span class="small font-monospace text-muted d-block">Cost: $\${parseFloat(p.cost_price).toFixed(2)}</span>
                            </div>
                        </div>
                    </div>
                \`;

                // Hover effects
                const card = col.querySelector('.product-card');
                card.addEventListener('mouseenter', () => card.classList.add('border-primary', 'bg-primary-light'));
                card.addEventListener('mouseleave', () => card.classList.remove('border-primary', 'bg-primary-light'));
                
                // Click handler
                card.addEventListener('click', () => {
                    selectProduct(p.id, p.name, p.category_name, stock, p.cost_price);
                });

                searchResults.appendChild(col);
            });
            
            // Auto select if it's an exact barcode scan resulting in 1 product
            if(products.length === 1 && searchInput.value.length > 5) {
                // optional: automatically trigger selection, but user might want to see it first.
            }
        }

        function selectProduct(id, name, category, stock, cost) {
            // Populate step 2
            productIdInput.value = id;
            document.getElementById('selName').textContent = name;
            document.getElementById('selCategory').textContent = category || 'Uncategorized';
            document.getElementById('selStock').textContent = stock;
            
            // Set default cost
            unitCostInput.value = parseFloat(cost).toFixed(2);
            calculateTotal();

            // UI Transitions
            step1.classList.add('d-none');
            step2.classList.remove('d-none');
            step2.classList.add('animate__animated', 'animate__fadeIn');
            
            // Update progress bar
            stepProgress.style.width = '100%';
            step2Indicator.classList.remove('bg-light', 'text-muted');
            step2Indicator.classList.add('bg-primary', 'text-white');
            step2Label.classList.remove('text-muted');
            step2Label.classList.add('text-primary');

            // Focus next input
            setTimeout(() => document.getElementById('supplier_name').focus(), 100);
        }

        changeProductBtn.addEventListener('click', () => {
            step2.classList.add('d-none');
            step1.classList.remove('d-none');
            step1.classList.add('animate__animated', 'animate__fadeIn');
            
            // Reset progress bar
            stepProgress.style.width = '50%';
            step2Indicator.classList.add('bg-light', 'text-muted');
            step2Indicator.classList.remove('bg-primary', 'text-white');
            step2Label.classList.add('text-muted');
            step2Label.classList.remove('text-primary');
            
            productIdInput.value = '';
            searchInput.focus();
        });

        // Compute total live
        function calculateTotal() {
            const q = parseInt(quantityInput.value) || 0;
            const c = parseFloat(unitCostInput.value) || 0;
            if (q > 0 && c >= 0) {
                const total = q * c;
                totalValueSpan.textContent = \`$\${total.toFixed(2)}\`;
                totalPreview.classList.remove('d-none');
            } else {
                totalPreview.classList.add('d-none');
            }
        }

        quantityInput.addEventListener('input', calculateTotal);
        unitCostInput.addEventListener('input', calculateTotal);
    });
</script>
`) %>
