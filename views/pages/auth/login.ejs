<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — CSRMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .login-page { height: 100vh; display: flex; overflow: hidden; background-color: #fff; }
        .login-left { width: 40%; background-color: #0F172A; display: flex; flex-direction: column; justify-content: center; padding: 4rem; color: #fff; position: relative; }
        .login-right { width: 60%; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 0 4rem; }
        .login-form-container { width: 100%; max-width: 440px; }
        .login-logo { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; background-color: var(--color-primary); border-radius: var(--border-radius-sm); margin-bottom: 2rem; }
        .login-logo-inner { width: 24px; height: 24px; background-color: #fff; border-radius: 4px; }
        .feature-item { display: flex; align-items: center; margin-bottom: 1rem; color: #94A3B8; font-size: 1.1rem; }
        .feature-icon { color: var(--color-success); margin-right: 1rem; font-size: 1.5rem; }
        .version-info { position: absolute; bottom: 2rem; left: 4rem; color: #64748B; font-size: 0.9rem; }
        .password-toggle { cursor: pointer; color: var(--color-text-muted); }
        @media (max-width: 991px) {
            .login-left { display: none; }
            .login-right { width: 100%; }
        }
    </style>
</head>
<body class="login-page">
    <div class="login-left">
        <div>
            <div class="login-logo">
                <div class="login-logo-inner"></div>
            </div>
            <h1 class="fw-bold mb-2">Crown Stores</h1>
            <p class="fs-4 text-muted mb-5">Retail Management System</p>
            
            <div class="features-list">
                <div class="feature-item">
                    <i class="bi bi-check-circle-fill feature-icon"></i>
                    <span>Centralized Branch Control</span>
                </div>
                <div class="feature-item">
                    <i class="bi bi-check-circle-fill feature-icon"></i>
                    <span>Real-time Inventory Sync</span>
                </div>
                <div class="feature-item">
                    <i class="bi bi-check-circle-fill feature-icon"></i>
                    <span>Advanced Analytics & Reports</span>
                </div>
            </div>
        </div>
        <div class="version-info">Version 1.0.0</div>
    </div>
    
    <div class="login-right">
        <div class="login-form-container">
            <h2 class="fw-bold mb-2" style="color: var(--color-text);">Welcome back</h2>
            <p class="text-muted mb-4">Please enter your credentials to access the system.</p>
            
            <% if (typeof messages !== 'undefined' && messages.error && messages.error.length > 0) { %>
                <div class="alert alert-danger" role="alert" style="border-radius: var(--border-radius-md); border-left: 4px solid var(--color-danger); background-color: var(--color-danger-light); border-color: var(--color-danger-light);">
                    <i class="bi bi-exclamation-triangle-fill me-2" style="color: var(--color-danger);"></i><span style="color: var(--color-text);"><%= messages.error[0] %></span>
                </div>
            <% } %>
            
            <% if (typeof messages !== 'undefined' && messages.success && messages.success.length > 0) { %>
                <div class="alert alert-success" role="alert" style="border-radius: var(--border-radius-md); border-left: 4px solid var(--color-success); background-color: var(--color-success-light); border-color: var(--color-success-light);">
                    <i class="bi bi-check-circle-fill me-2" style="color: var(--color-success);"></i><span style="color: var(--color-text);"><%= messages.success[0] %></span>
                </div>
            <% } %>

            <form action="/login" method="POST" id="loginForm">
                <div class="form-floating mb-3">
                    <input type="text" class="form-control" id="username" name="username" placeholder="Username" required autocomplete="username">
                    <label for="username"><i class="bi bi-person me-2"></i>Username</label>
                </div>
                
                <div class="form-floating mb-4 position-relative">
                    <input type="password" class="form-control" id="password" name="password" placeholder="Password" required autocomplete="current-password">
                    <label for="password"><i class="bi bi-lock me-2"></i>Password</label>
                    <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 password-toggle" id="togglePassword"></i>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" value="" id="rememberMe">
                        <label class="form-check-label text-muted" for="rememberMe">
                            Remember me
                        </label>
                    </div>
                    <a href="/forgot-password" class="text-decoration-none fw-semibold" style="color: var(--color-primary);">Forgot password?</a>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 py-3 mb-4" id="loginBtn" style="font-size: 1.1rem; border-radius: var(--border-radius-md);">
                    <span class="btn-text">Sign In</span>
                    <span class="spinner-border spinner-border-sm d-none ms-2" role="status" aria-hidden="true" id="loginSpinner"></span>
                </button>
            </form>
            
            <div class="text-center text-muted" style="font-size: 0.85rem;">
                For account issues contact your administrator
            </div>
        </div>
    </div>

    <script>
        document.getElementById('togglePassword').addEventListener('click', function () {
            const pwd = document.getElementById('password');
            if (pwd.type === 'password') {
                pwd.type = 'text';
                this.classList.remove('bi-eye');
                this.classList.add('bi-eye-slash');
            } else {
                pwd.type = 'password';
                this.classList.remove('bi-eye-slash');
                this.classList.add('bi-eye');
            }
        });
        
        document.getElementById('loginForm').addEventListener('submit', function() {
            const btn = document.getElementById('loginBtn');
            const spinner = document.getElementById('loginSpinner');
            // Give it brief time to submit before disabling
            setTimeout(() => {
                btn.disabled = true;
                spinner.classList.remove('d-none');
            }, 50);
        });
    </script>
</body>
</html>
